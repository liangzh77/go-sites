(main_site_routes) {
    handle /api/demo/* {
        reverse_proxy 127.0.0.1:9005
    }

    handle /api/demos* {
        reverse_proxy 127.0.0.1:9005
    }

    handle /api/wiki/* {
        reverse_proxy 127.0.0.1:9005
    }

    @tab_routes path /search /recommendations /ai-tools /dev-tools /tools /fun /works /private /demo /wiki
    handle @tab_routes {
        reverse_proxy 127.0.0.1:9005
    }

    handle /demo/* {
        reverse_proxy 127.0.0.1:9005
    }

    handle /wiki/* {
        reverse_proxy 127.0.0.1:9005
    }

    root * /srv/sites/liangz77.cn/current
    encode zstd gzip
    file_server
}

http://49.232.129.114 {
    import main_site_routes
}

http://liangz77.cn, http://www.liangz77.cn {
    redir https://liangz77.cn{uri} permanent
}

https://liangz77.cn {
    import main_site_routes
}

https://www.liangz77.cn {
